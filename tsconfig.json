{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext"],
    "types": ["jest"]
  },
  "include": ["src", "App.js"]
}
